# ── Production Database Configuration ─────────────────────────
POSTGRES_USER=cctv
POSTGRES_PASSWORD=your_strong_production_postgres_password_here
POSTGRES_DB=cctvdb

# Database connection URLs used by FastAPI and background workers.
# Note the host 'postgres' corresponds to the database service name in docker-compose.prod.yml.
DATABASE_URL=postgresql+asyncpg://cctv:your_strong_production_postgres_password_here@postgres:5432/cctvdb
DATABASE_URL_SYNC=postgresql://cctv:your_strong_production_postgres_password_here@postgres:5432/cctvdb

# ── Production Redis Configuration ────────────────────────────
REDIS_PASSWORD=your_strong_production_redis_password_here
REDIS_URL=redis://:your_strong_production_redis_password_here@redis:6379/0

# ── Security & JWT Configuration ──────────────────────────────
# Generate a high-entropy secret key using: openssl rand -hex 32
JWT_SECRET_KEY=your_secure_32_byte_hex_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Key used for column-level encryption. Generate using: cryptography.fernet.Fernet.generate_key()
# If left blank, it is automatically derived from JWT_SECRET_KEY as a fallback.
ENCRYPTION_KEY=

# ── Object Storage (S3-compatible) ───────────────────────────
# Point this to AWS S3, Cloudflare R2, MinIO, or DigitalOcean Spaces.
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY=your_production_s3_access_key
S3_SECRET_KEY=your_production_s3_secret_key
S3_BUCKET=cctv-production-media

# ── Production Email Configuration (SMTP) ─────────────────────
# Replace with your transactional email provider (SendGrid, Mailgun, AWS SES, etc.).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_smtp_provider_credential_here
SMTP_FROM=CCTV Platform <noreply@yourdomain.com>

# ── SMS / WhatsApp Gateway Credentials ────────────────────────
SMS_PROVIDER_API_KEY=your_sms_gateway_api_key_here
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/your_phone_number_id/messages
WHATSAPP_API_KEY=your_whatsapp_permanent_access_token_here

# ── Application Configuration ─────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# JSON array containing allowed CORS origins. MUST include your primary and wildcard subdomains.
CORS_ORIGINS=["https://yourdomain.com","https://*.yourdomain.com"]
