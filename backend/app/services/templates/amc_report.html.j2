<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AMC Consolidated Report — {{ contract.contract_number }}</title>
<style>
  /* ── Reset & Base ─────────────────────────────────────── */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: "Helvetica Neue", Arial, sans-serif;
    font-size: 10px;
    color: #1a202c;
    background: #fff;
  }
  h1 { font-size: 22px; }
  h2 { font-size: 13px; margin-bottom: 8px; color: #0f2a43; border-bottom: 2px solid #0f2a43; padding-bottom: 4px; }
  h3 { font-size: 11px; color: #4a5568; margin-bottom: 6px; }
  p  { margin-bottom: 4px; line-height: 1.5; }

  /* ── Page layout ─────────────────────────────────────── */
  @page {
    size: A4;
    margin: 14mm 14mm 20mm 14mm;
    @bottom-center {
      content: "Generated by CCTV AMC Management System  ·  " string(title) "  ·  Page " counter(page) " of " counter(pages);
      font-size: 8px;
      color: #718096;
    }
  }
  string-set: title "{{ contract.contract_number }}";

  .page-break { page-break-after: always; }

  /* ── Cover Page ──────────────────────────────────────── */
  .cover {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 250mm;
    text-align: center;
    background: linear-gradient(160deg, #0f2a43 0%, #1e4d72 100%);
    color: #fff;
    border-radius: 6px;
    padding: 40px;
  }
  .cover .badge {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .cover h1 { font-size: 26px; font-weight: 800; margin-bottom: 10px; line-height: 1.2; }
  .cover .subtitle { font-size: 13px; opacity: 0.85; margin-bottom: 30px; }
  .cover .meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 24px;
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 16px 24px;
    text-align: left;
    width: 100%;
    max-width: 360px;
  }
  .cover .meta-label { font-size: 8px; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.8px; }
  .cover .meta-value { font-size: 11px; font-weight: 700; margin-top: 2px; }
  .cover .generated { font-size: 8px; opacity: 0.55; margin-top: 24px; }

  /* ── Section wrapper ─────────────────────────────────── */
  .section { margin-bottom: 22px; }

  /* ── KPI Cards ───────────────────────────────────────── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 18px;
  }
  .kpi-card {
    background: #f7fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 12px 14px;
    text-align: center;
  }
  .kpi-card .kpi-label {
    font-size: 8px;
    color: #718096;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin-bottom: 6px;
  }
  .kpi-card .kpi-value {
    font-size: 22px;
    font-weight: 800;
    color: #0f2a43;
    line-height: 1;
  }
  .kpi-card .kpi-sub {
    font-size: 8px;
    color: #a0aec0;
    margin-top: 3px;
  }
  .kpi-card.green  .kpi-value { color: #276749; }
  .kpi-card.red    .kpi-value { color: #c53030; }
  .kpi-card.orange .kpi-value { color: #c05621; }
  .kpi-card.blue   .kpi-value { color: #2b6cb0; }

  /* ── Description table (2-col key-value) ─────────────── */
  .desc-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
  .desc-table td { padding: 5px 8px; border: 1px solid #e2e8f0; vertical-align: top; }
  .desc-table td:first-child {
    background: #edf2f7;
    font-weight: 600;
    white-space: nowrap;
    width: 38%;
    color: #2d3748;
  }

  /* ── Data tables ─────────────────────────────────────── */
  .data-table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
  .data-table thead tr { background: #0f2a43; color: #fff; }
  .data-table thead th {
    padding: 6px 8px;
    text-align: left;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.3px;
  }
  .data-table tbody tr:nth-child(even) { background: #f7fafc; }
  .data-table tbody tr:hover { background: #ebf4ff; }
  .data-table tbody td {
    padding: 5px 8px;
    border-bottom: 1px solid #e2e8f0;
    vertical-align: top;
    font-size: 9px;
  }
  .data-table tfoot td {
    padding: 6px 8px;
    font-weight: 700;
    background: #edf2f7;
    border-top: 2px solid #0f2a43;
  }

  /* ── Badges ──────────────────────────────────────────── */
  .badge-pill {
    display: inline-block;
    border-radius: 10px;
    padding: 1px 7px;
    font-size: 8px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .badge-green  { background: #c6f6d5; color: #276749; }
  .badge-red    { background: #fed7d7; color: #c53030; }
  .badge-orange { background: #feebc8; color: #c05621; }
  .badge-blue   { background: #bee3f8; color: #2b6cb0; }
  .badge-gray   { background: #e2e8f0; color: #4a5568; }
  .badge-purple { background: #e9d8fd; color: #553c9a; }

  /* ── Section header accent line ──────────────────────── */
  .section-number {
    display: inline-block;
    background: #0f2a43;
    color: #fff;
    border-radius: 4px;
    padding: 2px 7px;
    font-size: 9px;
    font-weight: 700;
    margin-right: 6px;
    vertical-align: middle;
  }
  h2 .section-number { vertical-align: middle; }

  /* ── Financial highlight ─────────────────────────────── */
  .fin-row-total td { font-weight: 800; font-size: 10px; background: #ebf8ff; }
  .amount-positive { color: #276749; font-weight: 700; }
  .amount-negative { color: #c53030; font-weight: 700; }

  /* ── Empty state ─────────────────────────────────────── */
  .empty-state {
    text-align: center;
    color: #a0aec0;
    font-style: italic;
    padding: 12px;
    background: #f7fafc;
    border-radius: 6px;
    margin-bottom: 10px;
  }

  /* ── Progress bar ────────────────────────────────────── */
  .progress-wrap { background: #e2e8f0; border-radius: 6px; height: 8px; width: 100%; margin-top: 4px; }
  .progress-fill { height: 8px; border-radius: 6px; background: #48bb78; }
  .progress-fill.warn { background: #ed8936; }
  .progress-fill.danger { background: #e53e3e; }
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════════════
     COVER PAGE
     ══════════════════════════════════════════════════════ -->
<div class="cover">
  <div class="badge">Confidential · AMC Report</div>
  <h1>Consolidated AMC Performance<br>&amp; Service Report</h1>
  <p class="subtitle">{{ customer.name | default('—') }}</p>
  <div class="meta-grid">
    <div>
      <div class="meta-label">Contract No.</div>
      <div class="meta-value">{{ contract.contract_number }}</div>
    </div>
    <div>
      <div class="meta-label">Status</div>
      <div class="meta-value">{{ contract.status | upper }}</div>
    </div>
    <div>
      <div class="meta-label">Contract Period</div>
      <div class="meta-value">{{ contract.start_date }} → {{ contract.end_date }}</div>
    </div>
    <div>
      <div class="meta-label">Report Period</div>
      <div class="meta-value">{{ report_period.from_date }} → {{ report_period.to_date }}</div>
    </div>
  </div>
  <p class="generated">Generated on {{ generated_at }}</p>
</div>

<div class="page-break"></div>

<!-- ══════════════════════════════════════════════════════
     SECTION 1 — EXECUTIVE SUMMARY
     ══════════════════════════════════════════════════════ -->
<div class="section">
  <h2><span class="section-number">1</span> Executive Summary</h2>
  <div class="kpi-grid">
    <!-- SLA Compliance -->
    <div class="kpi-card {% if kpis.sla_compliance_pct >= 90 %}green{% elif kpis.sla_compliance_pct >= 70 %}orange{% else %}red{% endif %}">
      <div class="kpi-label">SLA Compliance</div>
      <div class="kpi-value">{{ kpis.sla_compliance_pct }}%</div>
      <div class="kpi-sub">{{ kpis.sla_met }} met · {{ kpis.sla_breached }} breached</div>
    </div>
    <!-- PM Adherence -->
    <div class="kpi-card {% if kpis.pm_adherence_pct >= 90 %}green{% elif kpis.pm_adherence_pct >= 60 %}orange{% else %}red{% endif %}">
      <div class="kpi-label">PM Adherence</div>
      <div class="kpi-value">{{ kpis.pm_adherence_pct }}%</div>
      <div class="kpi-sub">{{ kpis.pm_done }} done · {{ kpis.pm_skipped }} skipped</div>
    </div>
    <!-- Total Visits -->
    <div class="kpi-card blue">
      <div class="kpi-label">Engineer Visits</div>
      <div class="kpi-value">{{ kpis.total_visits }}</div>
      <div class="kpi-sub">{{ kpis.corrective_visits }} corrective · {{ kpis.preventive_visits }} preventive</div>
    </div>
    <!-- Tickets Resolved -->
    <div class="kpi-card blue">
      <div class="kpi-label">Tickets Resolved</div>
      <div class="kpi-value">{{ kpis.tickets_resolved }}</div>
      <div class="kpi-sub">of {{ kpis.total_tickets }} total</div>
    </div>
    <!-- Total Collected -->
    <div class="kpi-card green">
      <div class="kpi-label">Amount Collected</div>
      <div class="kpi-value">₹{{ "{:,.0f}".format(kpis.total_collected) }}</div>
      <div class="kpi-sub">of ₹{{ "{:,.0f}".format(kpis.total_billed) }} billed</div>
    </div>
    <!-- Outstanding -->
    <div class="kpi-card {% if kpis.outstanding_balance > 0 %}orange{% else %}green{% endif %}">
      <div class="kpi-label">Outstanding</div>
      <div class="kpi-value">₹{{ "{:,.0f}".format(kpis.outstanding_balance) }}</div>
      <div class="kpi-sub">balance pending</div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     SECTION 2 — CONTRACT DETAILS
     ══════════════════════════════════════════════════════ -->
<div class="section">
  <h2><span class="section-number">2</span> Contract Details</h2>
  <table class="desc-table">
    <tr><td>Contract Number</td><td>{{ contract.contract_number }}</td></tr>
    <tr><td>Status</td><td>{{ contract.status | title }}</td></tr>
    <tr><td>Customer</td><td>{{ customer.name | default('—') }}</td></tr>
    <tr><td>Customer Category</td><td>{{ customer.category | default('—') | title }}</td></tr>
    <tr><td>Site Address</td><td>{{ customer.address | default('—') }}</td></tr>
    <tr><td>Contact Person</td><td>{{ customer.contact_person_name | default('—') }} {% if customer.contact_person_phone %}({{ customer.contact_person_phone }}){% endif %}</td></tr>
    <tr><td>GSTIN</td><td>{{ customer.gstin | default('—') }}</td></tr>
    <tr><td>Contract Start Date</td><td>{{ contract.start_date }}</td></tr>
    <tr><td>Contract End Date</td><td>{{ contract.end_date }}</td></tr>
    <tr><td>Annual AMC Value</td><td>₹{{ "{:,.2f}".format(contract.annual_amount) }}</td></tr>
    <tr><td>Payment Frequency</td><td>{{ contract.payment_frequency | default('—') | title }}</td></tr>
    <tr><td>Preventive Visits / Year</td><td>{{ contract.preventive_visits_per_year | default('—') }}</td></tr>
    {% if contract.terms %}
    <tr><td>Terms &amp; Conditions</td><td>{{ contract.terms }}</td></tr>
    {% endif %}
  </table>
</div>

<!-- ══════════════════════════════════════════════════════
     SECTION 3 — COVERED ASSETS
     ══════════════════════════════════════════════════════ -->
<div class="section">
  <h2><span class="section-number">3</span> Covered CCTV Assets ({{ assets | length }})</h2>
  {% if assets %}
  <table class="data-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Serial Number</th>
        <th>Make / Model</th>
        <th>Type</th>
        <th>Location</th>
        <th>Status</th>
        <th>Install Date</th>
        <th>Warranty Expiry</th>
      </tr>
    </thead>
    <tbody>
      {% for a in assets %}
      <tr>
        <td>{{ loop.index }}</td>
        <td>{{ a.serial_number | default('—') }}</td>
        <td>{{ a.make | default('') }} {{ a.model | default('') }}</td>
        <td>{{ a.asset_type | default('—') }}</td>
        <td>{{ a.location_description | default('—') }}</td>
        <td>
          {% if a.status == 'active' %}<span class="badge-pill badge-green">Active</span>
          {% elif a.status == 'faulty' %}<span class="badge-pill badge-red">Faulty</span>
          {% elif a.status == 'under_repair' %}<span class="badge-pill badge-orange">Under Repair</span>
          {% elif a.status == 'replaced' %}<span class="badge-pill badge-purple">Replaced</span>
          {% else %}<span class="badge-pill badge-gray">{{ a.status | title }}</span>{% endif %}
        </td>
        <td>{{ a.installation_date | default('—') }}</td>
        <td>{{ a.warranty_expiry | default('—') }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="empty-state">No assets linked to this contract.</div>
  {% endif %}
</div>

<div class="page-break"></div>

<!-- ══════════════════════════════════════════════════════
     SECTION 4 — SERVICE TICKET LOG
     ══════════════════════════════════════════════════════ -->
<div class="section">
  <h2><span class="section-number">4</span> Service Ticket Log ({{ tickets | length }} tickets)</h2>
  {% if tickets %}
  <table class="data-table">
    <thead>
      <tr>
        <th>Ticket #</th>
        <th>Date</th>
        <th>Priority</th>
        <th>Status</th>
        <th>SLA</th>
        <th>Complaint</th>
        <th>Resolution</th>
        <th>Resolved At</th>
      </tr>
    </thead>
    <tbody>
      {% for t in tickets %}
      <tr>
        <td>{{ t.ticket_number }}</td>
        <td>{{ t.created_at | default('—') }}</td>
        <td>
          {% if t.priority == 'critical' %}<span class="badge-pill badge-red">Critical</span>
          {% elif t.priority == 'high' %}<span class="badge-pill badge-orange">High</span>
          {% elif t.priority == 'medium' %}<span class="badge-pill badge-blue">Medium</span>
          {% else %}<span class="badge-pill badge-gray">Low</span>{% endif %}
        </td>
        <td>
          {% if t.status in ['resolved', 'closed'] %}<span class="badge-pill badge-green">{{ t.status | title }}</span>
          {% elif t.status == 'in_progress' %}<span class="badge-pill badge-blue">In Progress</span>
          {% elif t.status == 'pending_parts' %}<span class="badge-pill badge-orange">Pending Parts</span>
          {% else %}<span class="badge-pill badge-gray">{{ t.status | title }}</span>{% endif %}
        </td>
        <td>
          {% if t.sla_breached %}<span class="badge-pill badge-red">Breached</span>
          {% else %}<span class="badge-pill badge-green">Met</span>{% endif %}
        </td>
        <td>{{ (t.complaint or '')[:80] }}{% if (t.complaint or '') | length > 80 %}…{% endif %}</td>
        <td>{{ (t.resolution_notes or '')[:80] }}{% if (t.resolution_notes or '') | length > 80 %}…{% endif %}</td>
        <td>{{ t.resolved_at | default('—') }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="empty-state">No service tickets in this period.</div>
  {% endif %}
</div>

<!-- ══════════════════════════════════════════════════════
     SECTION 5 — ENGINEER VISIT LOG
     ══════════════════════════════════════════════════════ -->
<div class="section">
  <h2><span class="section-number">5</span> Engineer Visit Log ({{ visits | length }} visits)</h2>
  {% if visits %}
  <table class="data-table">
    <thead>
      <tr>
        <th>Type</th>
        <th>Check-in</th>
        <th>Check-out</th>
        <th>Duration</th>
        <th>Work Performed</th>
        <th>Parts Used</th>
        <th>Feedback</th>
      </tr>
    </thead>
    <tbody>
      {% for v in visits %}
      <tr>
        <td>
          {% if v.visit_type == 'preventive' %}<span class="badge-pill badge-blue">Preventive</span>
          {% else %}<span class="badge-pill badge-orange">Corrective</span>{% endif %}
        </td>
        <td>{{ v.checkin_at | default('—') }}</td>
        <td>{{ v.checkout_at | default('—') }}</td>
        <td>{% if v.duration_hrs %}{{ v.duration_hrs }} hrs{% else %}—{% endif %}</td>
        <td>{{ (v.work_performed or '')[:100] }}{% if (v.work_performed or '') | length > 100 %}…{% endif %}</td>
        <td>
          {% if v.parts_used %}
            {% for p in v.parts_used %}{{ p.description | default(p) }}{% if not loop.last %}, {% endif %}{% endfor %}
          {% else %}—{% endif %}
        </td>
        <td>{{ (v.customer_feedback or '')[:60] }}{% if (v.customer_feedback or '') | length > 60 %}…{% endif %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="empty-state">No engineer visits recorded in this period.</div>
  {% endif %}
</div>

<div class="page-break"></div>

<!-- ══════════════════════════════════════════════════════
     SECTION 6 — PREVENTIVE MAINTENANCE TRACKER
     ══════════════════════════════════════════════════════ -->
<div class="section">
  <h2><span class="section-number">6</span> Preventive Maintenance Tracker</h2>
  {% if pm_schedules %}
  <table class="data-table">
    <thead>
      <tr>
        <th>Seq #</th>
        <th>Scheduled Date</th>
        <th>Status</th>
        <th>Reason / Notes</th>
      </tr>
    </thead>
    <tbody>
      {% for pm in pm_schedules %}
      <tr>
        <td>{{ pm.sequence_no }}</td>
        <td>{{ pm.scheduled_date }}</td>
        <td>
          {% if pm.status == 'done' %}<span class="badge-pill badge-green">✓ Done</span>
          {% elif pm.status == 'skipped' %}<span class="badge-pill badge-red">✕ Skipped</span>
          {% elif pm.status == 'rescheduled' %}<span class="badge-pill badge-orange">↻ Rescheduled</span>
          {% else %}<span class="badge-pill badge-gray">Planned</span>{% endif %}
        </td>
        <td>{{ pm.reason_code or '' }} {{ pm.notes or '' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="empty-state">No PM schedule entries found for this contract.</div>
  {% endif %}
</div>

<!-- ══════════════════════════════════════════════════════
     SECTION 7 — FINANCIAL LEDGER
     ══════════════════════════════════════════════════════ -->
<div class="section">
  <h2><span class="section-number">7</span> Financial Ledger</h2>

  <h3>Invoices</h3>
  {% if invoices %}
  <table class="data-table">
    <thead>
      <tr>
        <th>Invoice #</th>
        <th>Date</th>
        <th>Due Date</th>
        <th>Status</th>
        <th style="text-align:right">Subtotal (₹)</th>
        <th style="text-align:right">GST (₹)</th>
        <th style="text-align:right">Total (₹)</th>
        <th style="text-align:right">Paid (₹)</th>
        <th style="text-align:right">Balance (₹)</th>
      </tr>
    </thead>
    <tbody>
      {% for inv in invoices %}
      <tr>
        <td>{{ inv.invoice_number }}</td>
        <td>{{ inv.invoice_date }}</td>
        <td>{{ inv.due_date | default('—') }}</td>
        <td>
          {% if inv.status == 'paid' %}<span class="badge-pill badge-green">Paid</span>
          {% elif inv.status == 'partially_paid' %}<span class="badge-pill badge-orange">Partial</span>
          {% elif inv.status == 'issued' %}<span class="badge-pill badge-blue">Issued</span>
          {% elif inv.status == 'cancelled' %}<span class="badge-pill badge-gray">Cancelled</span>
          {% else %}<span class="badge-pill badge-gray">{{ inv.status | title }}</span>{% endif %}
        </td>
        <td style="text-align:right">{{ "{:,.2f}".format(inv.subtotal) }}</td>
        <td style="text-align:right">{{ "{:,.2f}".format((inv.cgst_amount + inv.sgst_amount + inv.igst_amount)) }}</td>
        <td style="text-align:right">{{ "{:,.2f}".format(inv.total_amount) }}</td>
        <td style="text-align:right">{{ "{:,.2f}".format(inv.amount_paid) }}</td>
        <td style="text-align:right" class="{% if inv.balance > 0 %}amount-negative{% else %}amount-positive{% endif %}">
          {{ "{:,.2f}".format(inv.balance) }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="6" style="text-align:right">Totals</td>
        <td style="text-align:right">₹{{ "{:,.2f}".format(kpis.total_billed) }}</td>
        <td style="text-align:right">₹{{ "{:,.2f}".format(kpis.total_collected) }}</td>
        <td style="text-align:right" class="{% if kpis.outstanding_balance > 0 %}amount-negative{% else %}amount-positive{% endif %}">
          ₹{{ "{:,.2f}".format(kpis.outstanding_balance) }}
        </td>
      </tr>
    </tfoot>
  </table>
  {% else %}
  <div class="empty-state">No invoices raised against this contract.</div>
  {% endif %}

  <h3 style="margin-top:14px">Payments Received</h3>
  {% if payments %}
  <table class="data-table">
    <thead>
      <tr>
        <th>Payment Date</th>
        <th>Invoice</th>
        <th>Mode</th>
        <th>Reference #</th>
        <th style="text-align:right">Amount (₹)</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {% for p in payments %}
      <tr>
        <td>{{ p.payment_date }}</td>
        <td>
          {% for inv in invoices if inv.id == p.invoice_id %}{{ inv.invoice_number }}{% endfor %}
        </td>
        <td>{{ p.mode | upper }}</td>
        <td>{{ p.reference_number | default('—') }}</td>
        <td style="text-align:right" class="amount-positive">{{ "{:,.2f}".format(p.amount) }}</td>
        <td>{{ p.notes | default('—') }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4" style="text-align:right">Total Collected</td>
        <td style="text-align:right">₹{{ "{:,.2f}".format(kpis.total_collected) }}</td>
        <td></td>
      </tr>
    </tfoot>
  </table>
  {% else %}
  <div class="empty-state">No payments recorded against this contract's invoices.</div>
  {% endif %}
</div>

<!-- ══════════════════════════════════════════════════════
     SIGNATURE BLOCK
     ══════════════════════════════════════════════════════ -->
<div style="margin-top: 30px; border-top: 1px solid #e2e8f0; padding-top: 20px;">
  <table style="width:100%; border-collapse:collapse;">
    <tr>
      <td style="width:45%; text-align:center; padding:0 10px;">
        <div style="border-top: 1px solid #0f2a43; padding-top: 6px; margin-top: 40px; font-size:9px; color:#4a5568;">
          Authorised Signatory (Service Provider)
        </div>
      </td>
      <td style="width:10%"></td>
      <td style="width:45%; text-align:center; padding:0 10px;">
        <div style="border-top: 1px solid #0f2a43; padding-top: 6px; margin-top: 40px; font-size:9px; color:#4a5568;">
          Customer Acknowledgement — {{ customer.name | default('') }}
        </div>
      </td>
    </tr>
  </table>
</div>

</body>
</html>
