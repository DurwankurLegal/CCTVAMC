# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=cctv
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cctvdb
DATABASE_URL=postgresql+asyncpg://cctv:change_me@postgres:5432/cctvdb
DATABASE_URL_SYNC=postgresql://cctv:change_me@postgres:5432/cctvdb

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@redis:6379/0

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Object Storage (S3-compatible) ───────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me
S3_BUCKET=cctv-media

# ── Email ─────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change_me
SMTP_FROM=CCTV Platform <noreply@example.com>

# ── SMS / WhatsApp ────────────────────────────────────────────
SMS_PROVIDER_API_KEY=change_me
WHATSAPP_API_URL=https://api.whatsapp.example.com
WHATSAPP_API_KEY=change_me

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
